{
  "name": "@wyattjoh/dokploy-mcp",
  "version": "0.6.1",
  "description": "MCP server that wraps the Dokploy REST API",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/wyattjoh/dokploy-mcp.git"
  },
  "bin": {
    "dokploy-mcp": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "scripts": {
    "build": "bun build src/index.ts --target=node --outdir=dist --format=esm",
    "start": "bun run src/index.ts",
    "start:http": "bun run src/index.ts --http",
    "check": "bun run lint && bun run fmt:check && bun run typecheck && bun run build",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "fmt": "oxfmt .",
    "fmt:check": "oxfmt --check .",
    "typecheck": "bunx tsc --noEmit"
  },
  "devDependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@types/bun": "latest",
    "@types/express": "^5.0.6",
    "bun-types": "^1.3.11",
    "express": "^5.2.1",
    "oxfmt": "^0.44.0",
    "oxlint": "^1.58.0",
    "zod": "^4.3.6"
  },
  "peerDependencies": {
    "typescript": "^5"
  }
}
